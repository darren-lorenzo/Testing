FROM alpine:latest

# Create shared directory
WORKDIR /shared

# Simulate building the APK by creating a dummy file
# In a real scenario, this would involve installing Android SDK and building the project
CMD echo "Simulating APK build..." && \
    echo "Dummy APK content" > client.apk && \
    echo "APK created at /shared/client.apk" && \
    tail -f /dev/null
